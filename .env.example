# Meal Shield — Environment Variables
# Copy this file to .env and adjust values as needed.

# ── Model checkpoints ────────────────────────────────────────
# Paths to trained model files. The server uses these at startup.
# If not set, the server starts in demo mode with simulated predictions.
MODEL_CHECKPOINT=checkpoints/meal_shield_gnn.pt
TDA_MODEL_CHECKPOINT=checkpoints/meal_shield_gnn_tda.pt

# ── Optional: DistPepFold integration ────────────────────────
# Path to a local DistPepFold installation for 3D peptide structure
# prediction + docking-aware TDA features. Leave unset to skip.
# DISTPEPFOLD_DIR=/path/to/DistPepFold

# ── Server ───────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
